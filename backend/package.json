{
  "name": "yoobus-backend",
  "version": "1.0.0",
  "description": "Yoo Bus Mobility - Multi-tenant SaaS bus booking platform (NestJS + PostgreSQL + OSM)",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "seed": "ts-node src/database/seeds/seed.ts",
    "test:logic": "ts-node -P tsconfig.json test/logic.test.ts && ts-node -P tsconfig.json test/logic-extended.test.ts && ts-node -P tsconfig.json test/seat-fare.test.ts && ts-node -P tsconfig.json test/seat-layout.test.ts",
    "test:e2e": "ts-node -P tsconfig.json test/e2e-scenarios.ts",
    "test:api": "ts-node -P tsconfig.json test/api-matrix.ts",
    "routes:scan": "python3 scripts/scan-routes.py",
    "test:all": "npm run test:logic && npm run test:e2e && npm run test:api"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "express": "^4.22.2",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "nanoid": "^3.3.7",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "pino-http": "^10.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
