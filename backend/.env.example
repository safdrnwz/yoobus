NODE_ENV=development
APP_NAME=Yoo Bus
PORT=3000
API_PREFIX=api/v1
APP_PUBLIC_URL=http://localhost:3000/api/v1

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=yoobus_db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Must be at least 32 characters (enforced at boot).
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES=1d

# EMAIL: set EMAIL_DEV_MODE=false to actually SEND. true = only logs to console (nothing sent).
EMAIL_DEV_MODE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
SMTP_FROM=Yoo Bus <no-reply@yoobus.com>

# Billing / tax (confirm rates with your CA — defaults only)
SETUP_FEE_PER_BUS=4999
DEFAULT_COMMISSION_RATE=0.03
FARE_GST_RATE=0.05
COMMISSION_GST_RATE=0.18
TCS_RATE=0.01
TDS_RATE=0.001

# Platform superadmin (used by seed)
SUPERADMIN_EMAIL=superadmin@yoobus.com
SUPERADMIN_PASSWORD=Super@123

# Razorpay (server-only secret; never expose KEY_SECRET to frontend)
RAZORPAY_KEY_ID=rzp_test_T8AMlEyoQI0nw1
RAZORPAY_KEY_SECRET=4Sondjk7IPeXkDA0yNH48I8q

CORS_ORIGINS=*

# Login brute-force lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
MAX_BODY_SIZE=1mb

# Seed size (customers). Lower it for an even faster seed.
SEED_CUSTOMERS=1000

# SMS / WhatsApp (leave disabled to log only; enable + add creds to actually send)
NOTIFY_SMS_ENABLED=false
NOTIFY_WHATSAPP_ENABLED=false
MSG91_AUTHKEY=
MSG91_SENDER=THKBUS
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Dynamic pricing
DYNAMIC_PRICING_ENABLED=false

# ── Cloudinary CDN (file/image uploads) ─────────────────────────────────────
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# Get it from: Cloudinary Dashboard → Settings → API Keys.
# NEVER commit the real value — set it only in your local/server .env.
CLOUDINARY_URL=
CLOUDINARY_FOLDER=yoobus
UPLOAD_MAX_MB=5
