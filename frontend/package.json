{
  "name": "yoobus-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Yoo Bus Mobility \u2014 enterprise console (React + TypeScript)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "typecheck": "tsc --noEmit",
    "test:menu": "tsx test/role-menu.test.ts",
    "api:types": "cd .. && python3 tools/generate-api-types.py",
    "contract": "cd .. && python3 tools/contract-check.py",
    "test:all": "npm run contract && npm run test:menu",
    "forms": "cd .. && python3 tools/generate-forms.py",
    "audit:forms": "cd .. && python3 tools/audit-forms.py"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.14.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "5.7.2",
    "vite": "^6.0.3"
  }
}